flowchart TD
  %% Symbol legend:
  %%   [FH] = family-holiday instance
  %%   [HC] = home-care instance
  %%   [LM] = last-mile delivery instance
  A1[TSP]
  A1 --> B2[Nodes]
  B2 --> C3["I = {1,2,..., i, ...}"]
  C3 --> D4["[FH] Cities to visit"]
  C3 --> D5["[LM] Customers to visit"]
  C3 --> D6["[HC] Patients to visit"]
  C3 --> D7[A new instance]
  A1 --> B8[Edges]
  B8 --> C9["E = {ij for all i, j in I}"]
  C9 --> D10["[FH] Flights"]
  C9 --> D11["[LM] [HC] Roads"]
  C9 --> D12["[LM] [HC] Rails"]
  A1 --> B13[Costs]
  B13 --> C14[c_ij, for ij in E]
  C14 --> D15["[LM] [HC] Travel time"]
  C14 --> D16[Travel cost]
  D16 --> E17["[FH] Airfare"]
  D16 --> E18["[LM] [HC] Vehicle cost"]
  A1 --> B19[Service requirements]
  B19 --> C20[Service time]
  C20 --> D21[s_i for i in I]
  D21 --> E22["[LM] Servicing customers"]
  D21 --> E23["[HC] Examining patients"]
  A1 --> B24[Penalties]
  B24 --> C25[Punctuality]
  C25 --> D26[Earliness penalty]
  D26 --> E27[p_i^E for i in I]
  E27 --> F28["[LM] [HC] Arriving too early"]
  C25 --> D29[Lateness penalty]
  D29 --> E30[p_i^L for i in I]
  E30 --> F31["[LM] [HC] Arriving too late"]
  B24 --> C32[Missing nodes]
  C32 --> D33[p_i^M for i in I]
  D33 --> E34["[FH] Not visiting cities"]
  D33 --> E35["[LM] Not servicing customers"]
  D33 --> E36["[HC] Not visiting patients"]
  A1 --> B37[Nodes must be visited]
  B37 --> C38[I^- subset of I]
  C38 --> D39["[FH] Set of cities must be visited"]
  C38 --> D40["[LM] Set of customers must be visited"]
  C38 --> D41["[HC] Set of patients must be visited"]
  A1 --> B42[Values]
  B42 --> C43[w_i for i in I]
  C43 --> D44["[FH] Attractions"]
  C43 --> D45["[LM] [HC] Revenue"]
  C43 --> D46["[LM] [HC] Urgency"]
  A1 --> B47[Budget]
  B47 --> C48[Financial limit]
  C48 --> D49[b_max]
  D49 --> E50["[FH] Budget for holiday"]
  D49 --> E51["[LM] [HC] Budget for travel cost"]
  B47 --> C52[Time limit]
  C52 --> D53[t_max]
  D53 --> E54["[LM] [HC] Maximum travel/working time"]
  A1 --> B55[Time windows]
  B55 --> C56["[e_i, l_i] for i in I"]
  C56 --> D57["[LM] Customer availability"]
  C56 --> D58["[HC] Patient availability/schedule"]
  A1 --> B59[Objective]
  B59 --> C60[Minimization]
  C60 --> D61[Minimizing total cost]
  D61 --> E62["sum_{ij in E} c_ij x_ij"]
  E62 --> F63["[LM] [HC] Total travel time"]
  E62 --> F64["[LM] [HC] [FH] Total travel cost"]
  C60 --> D65[Minimizing total penalty]
  D65 --> E66[Penalizing unpunctuality]
  E66 --> F67["sum_{i in I} (p_i ^E z_i^E + p_i^L z_i^L)"]
  F67 --> G68["[LM] Visiting customers early or late"]
  F67 --> G69["[HC] Visiting patients early or late"]
  D65 --> E70[Penalizing missing nodes]
  E70 --> F71["sum_{i in I} p_i^M (1-y_i)"]
  F71 --> G72["[FH] Missing cities"]
  F71 --> G73["[LM] Missing customers"]
  F71 --> G74["[HC] Missing patients"]
  B59 --> C75[Maximization]
  C75 --> D76[Maximizing total value]
  D76 --> E77["sum_{i in I} w_i y_i"]
  E77 --> F78["[FH] Total value of joy"]
  E77 --> F79["[LM] [HC] Total revenue"]
  C75 --> D80[Maximizing total profit]
  D80 --> E81["sum_{i in I} (w_i y_i - p_i^M (1-y_i))"]
  E81 --> F82["[LM] [HC] Total profit"]
  A1 --> B83[Decision variables]
  B83 --> C84[Nodes visited]
  C84 --> D85[y_i = 0/1 for i in I]
  D85 --> E86["[FH] Visiting cities"]
  D85 --> E87["[LM] Visiting customers"]
  D85 --> E88["[HC] Visiting patients"]
  B83 --> C89[Edge traveled]
  C89 --> D90[x_ij = 0/1 for ij in E]
  D90 --> E91["[FH] Flight from city to another city"]
  D90 --> E92["[LM] Travel from customer to another customer"]
  D90 --> E93["[HC] Travel from patient to another patient"]
  B83 --> C94[Arrival time]
  C94 --> D95[a_i &gt;= 0 for i in I]
  D95 --> E96["[FH] Arrival time at city"]
  D95 --> E97["[LM] Arrival time at customer"]
  D95 --> E98["[HC] Arrival time at patient"]
  B83 --> C99[Early arrival]
  C99 --> D100[z_i^E = 0/1 for i in I]
  D100 --> E101["[FH] Arriving at city earlier than scheduled"]
  D100 --> E102["[LM] Arriving at customer earlier than scheduled"]
  D100 --> E103["[HC] Arriving at patient earlier than scheduled"]
  B83 --> C104[Late arrival]
  C104 --> D105[z_i^L = 0/1 for i in I]
  D105 --> E106["[FH] Arriving at city later than scheduled"]
  D105 --> E107["[LM] Arriving at customer later than scheduled"]
  D105 --> E108["[HC] Arriving at patient later than scheduled"]
  A1 --> B109[Constraints]
  B109 --> C110[Nodes must be visited]
  C110 --> D111[y_i = 1 for i in I^-]
  D111 --> E112["[FH] Cities must be visited"]
  D111 --> E113["[LM] Customers must be visited"]
  D111 --> E114["[HC] Patients must be visited"]
  B109 --> C115[Time window satisfaction]
  C115 --> D116["No violation (hard constraint)"]
  D116 --> E117[e_i &lt;= a_i &lt;= l_i for i in I]
  E117 --> F118["[LM] Must visit customers within their nominated time windows"]
  E117 --> F119["[HC] Must visit patients within their nominated time windows"]
  C115 --> D120["Penalizing violation (soft constraint)"]
  D120 --> E121[Earliness]
  E121 --> F122[M z_i^E &gt;= e_i - a_i for i in I]
  F122 --> G123["[LM] May visit customers earlier than their nominated time windows with penalty"]
  F122 --> G124["[HC] May visit patients earlier than their nominated time windows with penalty"]
  D120 --> E125[Lateness]
  E125 --> F126[M z_i^L &gt;= a_i - l_i for i in I]
  F126 --> G127["[LM] May visit customers later than their nominated time windows with penalty"]
  F126 --> G128["[HC] May visit patients later than their nominated time windows with penalty"]
  B109 --> C129[Budget]
  C129 --> D130[Financial limit]
  D130 --> E131["sum_{ij in E} c_ij x_ij &lt;= b_max"]
  E131 --> F132["[FH] Total expense no more than the budget"]
  C129 --> D133[Time limit]
  D133 --> E134["sum_{ij in E} c_ij x_ij + sum_{i in I} s_i y_i &lt;= t_max"]
  E134 --> F135["[LM] [HC] Total working time no more than the maximum"]
  D133 --> E136[a_i + s_i y_i &lt;= t_max for i in I]
  E136 --> F137["[LM] Leaving customers no later than the maximum time"]
  E136 --> F138["[HC] Leaving patients no later than the maximum time"]
  B109 --> C139[Loop]
  C139 --> D140[Closed loop]
  D140 --> E141["sum_{i in I} x_i0 = 1"]
  E141 --> F142["[FH] Returning home"]
  E141 --> F143["[LM] Returning to depot"]
  E141 --> F144["[HC] Returning to hospital"]
  C139 --> D145[Open loop]
  B109 --> C146[Visited nodes]
  C146 --> D147["y_i &lt;= sum_{j in I} x_ji for i in I"]
  B109 --> C148[Visiting no more than once]
  C148 --> D149["sum_{i in I} x_ij &lt;= 1 for j in I"]
  B109 --> C150[Flow balance]
  C150 --> D151["sum_{i in I} x_ij - sum_{i in I} x_ji = 0 for j in I"]
  B109 --> C152[Subtour elimination]
  C152 --> D153[DFJ]
  C152 --> D154[MTZ]
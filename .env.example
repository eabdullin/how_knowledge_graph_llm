# Required for GPT modeller, simulated-user, and judge configurations.
OPENAI_API_KEY=

# Configure Gemma or other models served by an OpenAI-compatible API.
# The API key may stay empty for local providers that do not require one.
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_BASE_URL=

# Provider-specific model identifiers, if they differ from these defaults.
GEMMA_31B_MODEL_ID=google/gemma-4-31b-it
GEMMA_E4B_MODEL_ID=google/gemma-4-E4B-it

# Optional per-model overrides for providers that use separate deployments.
# Empty values fall back to OPENAI_COMPATIBLE_BASE_URL/API_KEY.
GEMMA_31B_BASE_URL=
GEMMA_31B_API_KEY=
GEMMA_E4B_BASE_URL=
GEMMA_E4B_API_KEY=
